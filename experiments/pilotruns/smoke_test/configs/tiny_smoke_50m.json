{
  "run_name": "tiny_smoke_50m",
  "description": "Smallest pilot run to validate dataloader, loss, checkpointing, and generation on the 50M smoke shard.",
  "data_dir": "../tokenizer/data/tokenized/smoke_50m",
  "tokenizer": "../tokenizer/artifacts/tokenizer/toolcall_spm_32k.model",
  "out_dir": "runs/tiny_smoke_50m",
  "seq_len": 512,
  "batch_size": 8,
  "grad_accum": 4,
  "max_steps": 1000,
  "eval_interval": 100,
  "save_interval": 500,
  "learning_rate": 0.0003,
  "model": {
    "hidden_size": 256,
    "num_layers": 6,
    "num_heads": 4,
    "num_kv_heads": 2,
    "intermediate_size": 768,
    "dropout": 0.0
  }
}